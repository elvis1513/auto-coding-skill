{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/elvis1513/auto-coding-skill/blob/main/src/auto-coding-skill/data/contracts/orchestration-v1.schema.json",
  "title": "Auto Coding Orchestration Contract v1",
  "type": "object",
  "$ref": "#/$defs/classifyResult",
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mechanismPlan": {
      "type": "object",
      "required": ["required", "optional_when_beneficial", "forbidden", "not_required", "lifecycle_required", "rule"],
      "properties": {
        "required": { "$ref": "#/$defs/stringArray" },
        "optional_when_beneficial": { "$ref": "#/$defs/stringArray" },
        "forbidden": { "$ref": "#/$defs/stringArray" },
        "not_required": { "$ref": "#/$defs/stringArray" },
        "lifecycle_required": { "type": "boolean" },
        "rule": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^$|^[0-9a-f]{64}$"
    },
    "assignmentContractDescriptor": {
      "type": "object",
      "required": [
        "common",
        "writer",
        "reviewer"
      ],
      "properties": {
        "common": {
          "$ref": "#/$defs/stringArray"
        },
        "writer": {
          "$ref": "#/$defs/stringArray"
        },
        "reviewer": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    "agentAssignment": {
      "type": "object",
      "required": [
        "contract_version",
        "node_id",
        "task_id",
        "role",
        "base_sha",
        "scope",
        "depends_on",
        "acceptance"
      ],
      "properties": {
        "contract_version": {
          "const": 1
        },
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "explorer",
            "docs_researcher",
            "browser_debugger",
            "fixer",
            "reviewer"
          ]
        },
        "base_sha": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "$ref": "#/$defs/stringArray"
        },
        "acceptance": {
          "$ref": "#/$defs/stringArray"
        },
        "execution_mode": {
          "type": "string",
          "enum": ["direct", "isolated"]
        },
        "task_branch": {
          "type": "string",
          "minLength": 1
        },
        "worktree_path": {
          "type": "string",
          "minLength": 1
        },
        "owned_paths": {
          "$ref": "#/$defs/stringArray"
        },
        "diff_base": {
          "type": "string",
          "minLength": 1
        },
        "diff_head": {
          "type": "string",
          "minLength": 1
        },
        "diff_fingerprint": {
          "$ref": "#/$defs/fingerprint"
        },
        "owning_fixer": {
          "type": "string",
          "minLength": 1
        },
        "review_depth": {
          "enum": [
            "focused",
            "deep"
          ]
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "issued_at": {
          "type": "string",
          "minLength": 1
        },
        "deadline_at": {
          "type": "string",
          "minLength": 1
        },
        "scope_revision": {
          "type": "integer",
          "minimum": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "role": {
                "const": "fixer"
              }
            },
            "required": [
              "role"
            ]
          },
          "then": {
            "required": [
              "execution_mode",
              "owned_paths"
            ],
            "allOf": [
              {
                "if": {
                  "properties": {
                    "execution_mode": { "const": "isolated" }
                  },
                  "required": ["execution_mode"]
                },
                "then": {
                  "required": ["task_branch", "worktree_path"]
                }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "role": {
                "const": "reviewer"
              }
            },
            "required": [
              "role"
            ]
          },
          "then": {
            "required": [
              "diff_base",
              "diff_head",
              "diff_fingerprint",
              "owning_fixer"
            ]
          }
        }
      ],
      "additionalProperties": false
    },
    "agentResult": {
      "type": "object",
      "required": [
        "contract_version",
        "node_id",
        "role",
        "task_id",
        "base_sha",
        "status",
        "summary",
        "depends_on",
        "owned_paths",
        "changed_paths",
        "diff_fingerprint",
        "evidence",
        "findings",
        "verdict",
        "risks",
        "next_owner"
      ],
      "properties": {
        "contract_version": {
          "const": 1
        },
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "explorer",
            "docs_researcher",
            "browser_debugger",
            "fixer",
            "reviewer"
          ]
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "base_sha": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "completed",
            "blocked",
            "failed"
          ]
        },
        "summary": {
          "type": "string"
        },
        "depends_on": {
          "$ref": "#/$defs/stringArray"
        },
        "owned_paths": {
          "$ref": "#/$defs/stringArray"
        },
        "changed_paths": {
          "$ref": "#/$defs/stringArray"
        },
        "diff_fingerprint": {
          "$ref": "#/$defs/fingerprint"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "findings": {
          "$ref": "#/$defs/stringArray"
        },
        "verdict": {
          "enum": [
            "not-applicable",
            "ready-for-review",
            "approved",
            "changes-requested",
            "blocked"
          ]
        },
        "risks": {
          "$ref": "#/$defs/stringArray"
        },
        "next_owner": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "role": {
                "enum": [
                  "explorer",
                  "docs_researcher",
                  "browser_debugger",
                  "reviewer"
                ]
              }
            },
            "required": [
              "role"
            ]
          },
          "then": {
            "properties": {
              "changed_paths": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "role": {
                "enum": [
                  "explorer",
                  "docs_researcher",
                  "browser_debugger"
                ]
              }
            },
            "required": [
              "role"
            ]
          },
          "then": {
            "properties": {
              "owned_paths": {
                "maxItems": 0
              },
              "verdict": {
                "enum": [
                  "not-applicable",
                  "blocked"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "role": {
                "const": "fixer"
              }
            },
            "required": [
              "role"
            ]
          },
          "then": {
            "properties": {
              "verdict": {
                "enum": [
                  "ready-for-review",
                  "blocked"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "role": {
                "const": "reviewer"
              }
            },
            "required": [
              "role"
            ]
          },
          "then": {
            "properties": {
              "verdict": {
                "enum": [
                  "approved",
                  "changes-requested",
                  "blocked"
                ]
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "agentPlan": {
      "type": "object",
      "required": [
        "contract_version",
        "contract_schema",
        "strategy",
        "policies",
        "assignment_contract",
        "result_contract",
        "optional_roles",
        "stages",
        "constraints"
      ],
      "properties": {
        "contract_version": {
          "const": 1
        },
        "contract_schema": {
          "const": "data/contracts/orchestration-v1.schema.json"
        },
        "strategy": {
          "enum": [
            "main-only",
            "orchestrated-subagents"
          ]
        },
        "policies": {
          "type": "object"
        },
        "assignment_contract": {
          "$ref": "#/$defs/assignmentContractDescriptor"
        },
        "result_contract": {
          "$ref": "#/$defs/stringArray"
        },
        "optional_roles": {
          "$ref": "#/$defs/stringArray"
        },
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "mode",
              "roles",
              "depends_on"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "mode": {
                "type": "string",
                "minLength": 1
              },
              "roles": {
                "$ref": "#/$defs/stringArray"
              },
              "depends_on": {
                "$ref": "#/$defs/stringArray"
              }
            },
            "additionalProperties": true
          }
        },
        "constraints": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    "classifyResult": {
      "type": "object",
      "required": [
        "contract_version",
        "contract_schema",
        "changed_files",
        "planned_files",
        "classification_files",
        "intent_provided",
        "intent_categories",
        "intent_risk_candidates",
        "high_confidence_intent_categories",
        "task_kind",
        "profile",
        "categories",
        "recommended_agents",
        "optional_agents",
        "agent_plan",
        "mechanism_plan"
      ],
      "properties": {
        "contract_version": {
          "const": 1
        },
        "contract_schema": {
          "const": "data/contracts/orchestration-v1.schema.json"
        },
        "changed_files": {
          "$ref": "#/$defs/stringArray"
        },
        "planned_files": {
          "$ref": "#/$defs/stringArray"
        },
        "classification_files": {
          "$ref": "#/$defs/stringArray"
        },
        "intent_provided": {
          "type": "boolean"
        },
        "intent_categories": {
          "$ref": "#/$defs/stringArray"
        },
        "intent_risk_candidates": {
          "$ref": "#/$defs/stringArray"
        },
        "high_confidence_intent_categories": {
          "$ref": "#/$defs/stringArray"
        },
        "task_kind": {
          "enum": ["none", "read_only", "change", "terminal_maintenance"]
        },
        "profile": {
          "enum": [
            "micro",
            "standard",
            "high-risk"
          ]
        },
        "categories": {
          "$ref": "#/$defs/stringArray"
        },
        "recommended_agents": {
          "$ref": "#/$defs/stringArray"
        },
        "optional_agents": {
          "$ref": "#/$defs/stringArray"
        },
        "agent_plan": {
          "$ref": "#/$defs/agentPlan"
        },
        "mechanism_plan": {
          "$ref": "#/$defs/mechanismPlan"
        }
      },
      "additionalProperties": true
    }
  }
}
